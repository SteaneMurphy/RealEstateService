# Firebase web config (client-side; safe to expose, but keep out of git)
VITE_API_KEY=your_firebase_api_key
VITE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_PROJECT_ID=your_project_id
VITE_STORAGE_BUCKET=your_project.appspot.com
VITE_MESSAGING_SENDER_ID=your_sender_id
VITE_APP_ID=your_app_id
VITE_MEASUREMENT_ID=your_measurement_id

# CoreLogic API — only needed to (re)seed Firestore, not at runtime.
# Ideally these belong on a backend, not in a client-side VITE_ variable.
VITE_CORELOGIC_KEY=your_corelogic_key
VITE_CORELOGIC_SECRET=your_corelogic_secret
